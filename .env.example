# Site URL (used for metadata, sitemap, and absolute links)
NEXT_PUBLIC_SITE_URL=

# Google Maps (service area map on contact page)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Google Analytics (GA4 measurement ID, e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Resend (contact form transactional email)
RESEND_API_KEY=

# Verified Resend sender, e.g. "Theo's Detailing Service LLC <quotes@yourdomain.com>"
# Falls back to onboarding@resend.dev for local testing
RESEND_FROM_EMAIL=

# Business contact (email destination for form submissions)
# Confirmed business email: theosadetailing@gmail.com
CONTACT_EMAIL=theosadetailing@gmail.com

# Business information (used in footer, contact page, and structured data)
BUSINESS_PHONE=
BUSINESS_ADDRESS=
BUSINESS_NAME=
